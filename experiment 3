#include <stdio.h>
#define MAX 10

int queue[MAX];
int front = -1, rear = -1;

// Insert process into ready queue
void enqueue(int pid) {
    if (rear == MAX - 1) {
        printf("Ready Queue is Full!\n");
        return;
    }
    if (front == -1)
        front = 0;
    queue[++rear] = pid;
    printf("Process P%d added to Ready Queue.\n", pid);
}

// Remove process from ready queue
int dequeue() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
        return -1;
    }
    return queue[front++];
}

// Display ready queue
void display() {
    if (front == -1 || front > rear) {
        printf("Ready Queue is Empty!\n");
        return;
    }

    printf("Ready Queue: ");
    for (int i = front; i <= rear; i++)
        printf("P%d ", queue[i]);
    printf("\n");
}

int main() {
    enqueue(1);
    enqueue(2);
    enqueue(3);

    display();

    int process = dequeue();
    if (process != -1)
        printf("Process P%d is executing.\n", process);

    display();

    enqueue(4);
    display();

    return 0;
}
