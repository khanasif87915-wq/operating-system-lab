#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int main() {
    pid_t pid1, pid2;

    // Create first child
    pid1 = fork();

    if (pid1 == 0) {
        // First child process
        printf("First Child: PID = %d, Parent PID = %d\n", getpid(), getppid());
    } else {
        // Parent creates second child
        pid2 = fork();

        if (pid2 == 0) {
            // Second child process
            printf("Second Child: PID = %d, Parent PID = %d\n", getpid(), getppid());
        } else {
            // Parent process
            printf("Parent: PID = %d\n", getpid());
            printf("First Child PID = %d\n", pid1);
            printf("Second Child PID = %d\n", pid2);
        }
    }

    return 0;
}
